# -------------------------------------------------#
# Bulk phase study
# -------------------------------------------------#
# 1) Plots the average plaquette for tuned Mobius
#    action as a function of the bare masses and 
#    their HMC-time evolution.
#    Plots the average plaquette for Shamir 
#    action as a function of beta and the bare
#    masses. Pure YM data and residual mass
#    data are also shown                              
# -------------------------------------------------#


rule bulk_phase:
    input:
        ensembles_csv="metadata/ensembles.csv",

        # tuned Möbius
        tuned_avg=lambda wc: load_and_expand(
            wc,
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "hmc/log_hmc_extract.json",
            flag="use_in_bulkphase_tuned",
        ),

        # Shamir bulk phase
        shamir_avg=lambda wc: load_and_expand(
            wc,
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "hmc/log_hmc_extract.json",
            flag="use_in_bulkphase_Shamir",
        ),

        # YM references (NF0)
        ym_avg=lambda wc: load_and_expand(
            wc,
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/B{beta}/"
            "hmc/log_hmc_extract.json",
            flag="use_in_YM",
        ),

        # mres Shamir
        mres_shamir=lambda wc: load_and_expand(
            wc,
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "residual_mass/m_res.json",
            flag="use_in_bulkphase_mres",
        ),
    output:
        tuned_masses="assets/plots/bulk_phase/mobius_tuned_plaq_vs_mass.pdf",
        tuned_history="assets/plots/bulk_phase/mobius_tuned_plaq_history.pdf",
        shamir_summary="assets/plots/bulk_phase/plaq_mass_beta_shamir.pdf",
    conda:
        "envs/analysis.yml"
    shell:
        (
            "python src/bulk_phase/bulk_phase.py "
            "--ensembles_csv {input.ensembles_csv} "
            "--plaq_avg {input.tuned_avg} {input.shamir_avg} {input.ym_avg} "
            "--mres_data {input.mres_shamir} "
            "--label {config[label]} "
            "--plot_styles '{config[plot_styles]}' "
            "--tuned_masses {output.tuned_masses} "
            "--tuned_history {output.tuned_history} "
            "--shamir_summary {output.shamir_summary}"
        )


