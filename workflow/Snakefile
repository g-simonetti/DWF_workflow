        "envs/analysis.yml"
    shell:
        "python src/hmc/table_hmc.py "
        "--hmc {input.hmc} "
        "--metadata_csv {input.metadata} "
        "--output_table {output.table} "
        "--use {wildcards.use}"


rule table_finite_volume:
    input:
        fv = lambda wc: load_and_expand(
            wc, 
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "finite_volume/finite_volume.json",
            flag="use_in_finite_volume"
        ),
	
        metadata = "metadata/ensembles.csv"
    output:
        table = "assets/finite_volume/table_finite_volume.tex"
    conda:
        "envs/analysis.yml"
    shell:
        "python src/finite_volume/finite_volume_table.py "
        "--fv {input.fv} "
        "--metadata_csv {input.metadata} "
        "--output_table {output.table}"
        



# -------------------------------------------------#
# Copy to assets
# -------------------------------------------------#
# 1) Spectrum plots
# 2) mres plots                           
# -------------------------------------------------#


rule copy_spectrum_to_assets:
    input:
        PS_fit="intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/spectrum/ps_plot.pdf",
        V_fit= "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/spectrum/v_plot.pdf",
    output:
        PS_fit_cp=(
            "assets/plots/spectrum/mesons_fits/"
            "PS_NF{NF}_B{beta}M{mass}_Nt{Nt}Ns{Ns}Ls{Ls}_mpv{mpv}alpha{alpha}a5{a5}M5{M5}.pdf"
        ),
        V_fit_cp=(
            "assets/plots/spectrum/mesons_fits/"
            "V_NF{NF}_B{beta}M{mass}_Nt{Nt}Ns{Ns}Ls{Ls}_mpv{mpv}alpha{alpha}a5{a5}M5{M5}.pdf"
        ),
    shell:
        r"""
        cp "{input.PS_fit}" "{output.PS_fit_cp}"
        cp "{input.V_fit}" "{output.V_fit_cp}"
        """



