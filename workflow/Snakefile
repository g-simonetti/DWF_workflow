###############
## Snakefile ##
###############

import pandas
from snakemake.io import multiext, expand

configfile: "config/config.yaml"


# -------------------------------------------------#
# Load ensembles CSV 
# -------------------------------------------------#

ENSEMBLES_DF = pandas.read_csv(
    "metadata/ensembles.csv",
    sep=r"\t|,",
    engine="python",
)


# -------------------------------------------------#
# Helpers                                           
# -------------------------------------------------#

def is_true(x):
    return str(x).strip().upper() in {"TRUE", "T", "1", "YES", "Y"}


def resolve_flag(wc, flag=None):
    """
    Default selection column is: use_in_{use}.

    NOTE: keep {use} free of "/" to avoid weird column names and directory issues.
    """
    if flag is None:
        return f"use_in_{wc.use}"
    return flag.format(**wc)



def load_and_expand(wc, pattern, flag=None):
    df = ENSEMBLES_DF

    flagcol = resolve_flag(wc, flag)
    if flagcol not in df.columns:
        raise ValueError(f"Column '{flagcol}' not found in metadata/ensembles.csv")

    df_sel = df[df[flagcol].apply(is_true)]

    out = []

    for _, row in df_sel.iterrows():

        # YM ensemble
        if is_true(row["YM"]):
            out.extend(
                expand(
                    pattern,
                    Nt=int(row["Nt"]),
                    Ns=int(row["Ns"]),
                    beta=row["beta"],
                )
            )

        # Dynamical ensemble
        else:
            out.extend(
                expand(
                    pattern,
                    NF=int(row["NF"]),
                    Nt=int(row["Nt"]),
                    Ns=int(row["Ns"]),
                    Ls=int(row["Ls"]),
                    beta=row["beta"],
                    mass=row["mass"],
                    mpv=row["mpv"],
                    alpha=row["alpha"],
                    a5=row["a5"],
                    M5=row["M5"],
                )
            )

    return out



def find_query(wc):

    # YM ensembles (no NF, Ls, etc.)
    if not hasattr(wc, "NF"):
        return (
            "YM == 'yes' "
            f"and Nt == {wc.Nt} "
            f"and Ns == {wc.Ns} "
            f"and beta == {wc.beta}"
        )

    # Dynamical ensembles (same as your original, just prefixed)
    return (
        f"NF == {wc.NF} "
        f"and Nt == {wc.Nt} "
        f"and Ns == {wc.Ns} "
        f"and Ls == {wc.Ls} "
        f"and beta == {wc.beta} "
        f"and mass == {wc.mass} "
        f"and alpha == {wc.alpha} "
        f"and a5 == {wc.a5} "
        f"and M5 == {wc.M5} "
        f"and mpv == {wc.mpv}"
    )



def lookup(within, query, cols):
    df = within.query(query)
    if len(df) != 1:
        raise ValueError(f"lookup expected 1 row, got {len(df)} for query: {query}")
    return df.iloc[0][cols]


# -------------------------------------------------#
# Residual mass rules
# -------------------------------------------------#
# 1) Extract the residual mass
# 2) Plots the residual mass as a function of 
#    the unphysical parameters
# 3) Plots the residual mass as a function of Ls 
#    and time elapsed per trajectory                                            
# -------------------------------------------------#


rule m_res:
    input:
        "raw_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
        "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
        "mesons"
    output:
        data =
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "residual_mass/m_res.txt",
        fit  =
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "residual_mass/m_res_fit.txt",
        plot = multiext(
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "residual_mass/mres_t",
            config["plot_filetype"],
        )
    params:
        plateau_start = lambda wc: lookup(ENSEMBLES_DF, find_query(wc), "mres_p_start"),
        plateau_end   = lambda wc: lookup(ENSEMBLES_DF, find_query(wc), "mres_p_end"),
    conda:
        "envs/analysis.yml"
    shell:
        (
            "python src/residual_mass/residual_mass_plateau.py {input} "
            "--label {config[label]} "
            "--output_file1 {output.data} "
            "--output_file2 {output.fit} "
            "--plot_file {output.plot} "
            "--plot_styles {config[plot_styles]} "
            "--plateau_start {params.plateau_start} "
            "--plateau_end {params.plateau_end} "
            "--beta {wildcards.beta} "
            "--mass {wildcards.mass} "
            "--alpha {wildcards.alpha} "
            "--a5 {wildcards.a5} "
            "--m5 {wildcards.M5} "
            "--mpv {wildcards.mpv}"
        )



rule plot_mres_scan:
    input:
        mres = lambda wc: load_and_expand(
            wc,
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "residual_mass/m_res_fit.txt"
        )
    output:
        "assets/plots/parameter_scan/mres_{use}.pdf"
    conda:
        "envs/analysis.yml"
    shell:
        (
            "python src/parameter_scan/plot_mres_scan.py {input.mres} "
            "--output_filename {output} "
            "--label {config[label]} "
            "--plot_styles {config[plot_styles]}"
        )



rule plot_cost_Ls:
    input:
        mres=lambda wc: load_and_expand(
            wc,
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "residual_mass/m_res_fit.txt"
        ),
        hmc=lambda wc: load_and_expand(
            wc,
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "hmc/log_hmc_extract.txt"
        )
    output:
        ls_scan="assets/plots/parameter_scan/mres_{use}_Shamir_vs_Mobius.pdf",
        costs="assets/plots/parameter_scan/mres_{use}_Shamir_vs_Mobius_costs.pdf"
    conda:
        "envs/analysis.yml"
    shell:
        "python src/parameter_scan/plot_mres_cost_Ls.py "
        "--mres {input.mres} "
        "--hmc {input.hmc} "
        "--label {config[label]} "
        "--ls_scan {output.ls_scan} "
        "--costs {output.costs} "
        "--plot_styles {config[plot_styles]}"


# -------------------------------------------------#
# Log files analysis rules
# -------------------------------------------------#
# 1) Extract the average plaquette and its
#    integrated autocorrelation time 
# 2) Same for Yang-Mills                                       
# -------------------------------------------------#


rule log_process:
    input:
        "raw_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
        "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
        "log"
    output:
        hmc_extract =
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "hmc/log_hmc_extract.txt",
        hmc_plaq =
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "hmc/plaq_history.txt",
    conda:
        "envs/analysis.yml"
    params:
        therm = lambda wc: lookup(ENSEMBLES_DF, find_query(wc), "therm"),
        delta = lambda wc: lookup(ENSEMBLES_DF, find_query(wc), "delta_traj"),
        name  = lambda wc: lookup(ENSEMBLES_DF, find_query(wc), "name"),
    shell:
        "python src/hmc/log_ensembles_extract_berg.py {input} "
        "--name {params.name} "
        "--therm {params.therm} "
        "--delta_traj {params.delta} "
        "--hmc_extract {output.hmc_extract} "
        "--hmc_plaq {output.hmc_plaq}"


rule log_process_YM:
    input:
        "raw_data/yang_mills/Nt{Nt}/Ns{Ns}/B{beta}/log"
    output:
        hmc_extract =
            "intermediary_data/yang_mills/Nt{Nt}/Ns{Ns}/B{beta}/hmc/log_hmc_extract.txt",
        hmc_plaq =
            "intermediary_data/yang_mills/Nt{Nt}/Ns{Ns}/B{beta}/hmc/plaq_history.txt",
    conda:
        "envs/analysis.yml"
    params:
        therm = lambda wc: lookup(ENSEMBLES_DF, find_query(wc), "therm"),
        delta = lambda wc: lookup(ENSEMBLES_DF, find_query(wc), "delta_traj"),
        name  = lambda wc: lookup(ENSEMBLES_DF, find_query(wc), "name"),
    shell:
        "python src/hmc/log_ensembles_extract_berg.py {input} "
        "--name {params.name} "
        "--therm {params.therm} "
        "--delta_traj {params.delta} "
        "--hmc_extract {output.hmc_extract} "
        "--hmc_plaq {output.hmc_plaq}"


# -------------------------------------------------#
# Bulk phase study
# -------------------------------------------------#
# 1) Plots the average plaquette for tuned Mobius
#    action as a function of the bare masses and 
#    their HMC-time evolution
# 2) Plots the average plaquette for Shamir 
#    action as a function of beta and the bare
#    masses. Pure YM data are also shown                              
# -------------------------------------------------#


rule bulk_phase:
    input:
        ensembles_csv = "metadata/ensembles.csv",
        # tuned Mobius
        tuned_avg = lambda wc: load_and_expand(
            wc, "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
                "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
                "hmc/log_hmc_extract.txt",
            flag="use_in_bulkphase_tuned"
        ),

        tuned_hist = lambda wc: load_and_expand(
            wc, "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
                "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
                "hmc/plaq_history.txt",
            flag="use_in_bulkphase_tuned"
        ),

        # Shamir bulk phase
        shamir_avg = lambda wc: load_and_expand(
            wc, "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
                "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/hmc/"
                "log_hmc_extract.txt",
            flag="use_in_bulkphase_Shamir"
        ),

        # YM references
        ym_avg = lambda wc: load_and_expand(
            wc, "intermediary_data/yang_mills/Nt{Nt}/Ns{Ns}/B{beta}/"
                "hmc/log_hmc_extract.txt",
            flag="use_in_YM"
        ),

        # mres Shamir
        mres_shamir = lambda wc: load_and_expand(
            wc, "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
                "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
                "residual_mass/m_res_fit.txt",
            flag="use_in_bulkphase_mres"
        ),
    output:
        tuned_masses   = "assets/plots/bulk_phase/mobius_tuned_plaq_vs_mass.pdf",
        tuned_history  = "assets/plots/bulk_phase/mobius_tuned_plaq_history.pdf",
        shamir_summary = "assets/plots/bulk_phase/plaq_mass_beta_shamir.pdf",
    conda:
        "envs/analysis.yml"
    shell:
        "python src/bulk_phase/bulk_phase.py "
        "--ensembles_csv {input.ensembles_csv} "
        "--plaq_avg {input.tuned_avg} {input.shamir_avg} {input.ym_avg} "
        "--mres_data {input.mres_shamir} "
        "--plaq_history {input.tuned_hist} "
        "--label {config[label]} "
        "--plot_styles {config[plot_styles]} "
        "--tuned_masses {output.tuned_masses} "
        "--tuned_history {output.tuned_history} "
        "--shamir_summary {output.shamir_summary} "





