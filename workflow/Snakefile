import pandas
from snakemake.io import multiext, expand

configfile: "config/config.yaml"


# -------------------------------------------------#
# Load ensembles CSV 
# -------------------------------------------------#

ENSEMBLES_DF = pandas.read_csv(
    "metadata/ensembles.csv",
    sep=r"\t|,",
    engine="python",
).convert_dtypes()


# -------------------------------------------------#
# Helpers                                           
# -------------------------------------------------#

def resolve_flag(wc, flag=None):
    """
    Default selection column is: use_in_{use}.
    """
    if flag is None:
        # Use .get to avoid error if rule doesn't have {use} wildcard
        use_val = getattr(wc, "use", "default") 
        return f"use_in_{use_val}"
    
    # Safely format the flag string with wildcards
    try:
        return flag.format(**wc)
    except KeyError:
        return flag



def load_and_expand(wc, pattern, flag=None):
    df = ENSEMBLES_DF.copy()

    flagcol = resolve_flag(wc, flag)
    if flagcol not in df.columns:
        raise ValueError(f"Column '{flagcol}' not found in metadata/ensembles.csv")

    # First: apply the flag selection
    df = df[df[flagcol] == True]

    # Then: if the rule output has beta/mass wildcards, restrict to them
    if hasattr(wc, "beta"):
        df = df[df["beta"].astype(str) == str(wc.beta)]

    if hasattr(wc, "mass"):
        df = df[df["mass"].astype(str) == str(wc.mass)]

    if df.empty:
        raise ValueError(
            f"No ensembles found for flag={flagcol}, beta={getattr(wc, 'beta', None)}, "
            f"mass={getattr(wc, 'mass', None)}"
        )

    out = []
    use_subdir = "{subdir}" in pattern

    for _, row in df.iterrows():
        NF = int(row["NF"])
        Nt = int(row["Nt"])
        Ns = int(row["Ns"])
        beta = row["beta"]

        if use_subdir:
            if NF == 0:
                subdir = f"B{beta}"
            else:
                subdir = (
                    f"Ls{int(row['Ls'])}/"
                    f"B{beta}/"
                    f"M{row['mass']}/"
                    f"mpv{row['mpv']}/"
                    f"alpha{row['alpha']}/"
                    f"a5{row['a5']}/"
                    f"M5{row['M5']}"
                )

            out.extend(
                expand(
                    pattern,
                    NF=NF,
                    Nt=Nt,
                    Ns=Ns,
                    subdir=subdir,
                )
            )

        else:
            if NF == 0:
                out.extend(
                    expand(
                        pattern,
                        NF=0,
                        Nt=Nt,
                        Ns=Ns,
                        beta=beta,
                    )
                )
            else:
                out.extend(
                    expand(
                        pattern,
                        NF=NF,
                        Nt=Nt,
                        Ns=Ns,
                        Ls=int(row["Ls"]),
                        beta=beta,
                        mass=row["mass"],
                        mpv=row["mpv"],
                        alpha=row["alpha"],
                        a5=row["a5"],
                        M5=row["M5"],
                    )
                )

    return out



'''
