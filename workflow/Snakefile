def find_query(wc):
    # YM ensembles (no NF, Ls, etc.)
    if not hasattr(wc, "NF"):
        return (
            "YM == 'yes' "
            f"and Nt == {wc.Nt} "
            f"and Ns == {wc.Ns} "
            f"and beta == {wc.beta}"
        )

    # Mobius/Shamir ensembles
    return (
        f"NF == {wc.NF} "
        f"and Nt == {wc.Nt} "
        f"and Ns == {wc.Ns} "
        f"and Ls == {wc.Ls} "
        f"and beta == {wc.beta} "
        f"and mass == {wc.mass} "
        f"and alpha == {wc.alpha} "
        f"and a5 == {wc.a5} "
        f"and M5 == {wc.M5} "
        f"and mpv == {wc.mpv}"
    )


def lookup(within, query, cols):
    df = within.query(query)
    if len(df) != 1:
        raise ValueError(f"lookup expected 1 row, got {len(df)} for query: {query}")
    return df.iloc[0][cols]


def metadata_lookup(variable_name):
    def metadata_lookup_inner(wildcards):
        val = lookup(ENSEMBLES_DF, find_query(wildcards), variable_name)
        # Check if the value is a Pandas <NA>, None, or NaN
        if pandas.isna(val):
            return -1  # Or whatever default your src/spectrum/spectrum.py expects for "auto"
        return val

    return metadata_lookup_inner

# -------------------------------------------------#
# Residual mass rules
# -------------------------------------------------#
# 1) Extracts the residual mass series and
#    a correlated fitted value
# 2) Plots the residual mass as a function of 
#    the unphysical parameters. Using scan_beta
#    it residual the residual mass series 
#    as a function of t/a for two volumes and
#    different betas and masses
# 3) Plots the residual mass as a function of Ls 
#    and time elapsed per trajectory                                            
# -------------------------------------------------#


rule m_res:
    input:
        "raw_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
        "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
        "mesons"
    output:
        mres_out =
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "residual_mass/m_res.json",
        plot = multiext(
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/"
            "B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/"
            "residual_mass/mres_t",
            config["plot_filetype"],
        )
    params:
        plateau_start = metadata_lookup("mres_p_start"),
        plateau_end   = metadata_lookup("mres_p_end"),
        therm         = metadata_lookup("therm"),
        delta_traj_ps = metadata_lookup("delta_traj_ps"),
    conda:
        "envs/analysis.yml"
    shell:
        (
            "python src/residual_mass/residual_mass_fit.py {input} "
            "--label {config[label]} "
            "--mres_out {output.mres_out} "
            "--plot_file {output.plot} "
            "--plot_styles {config[plot_styles]} "
            "--plateau_start {params.plateau_start} "
            "--plateau_end {params.plateau_end} "
            "--therm {params.therm} "
            "--delta_traj_ps {params.delta_traj_ps} "
            "--Nt {wildcards.Nt} "
	    "--Ns {wildcards.Ns} "
            "--Ls {wildcards.Ls} "
            "--beta {wildcards.beta} "
            "--mass {wildcards.mass} "
            "--alpha {wildcards.alpha} "
            "--a5 {wildcards.a5} "
            "--m5 {wildcards.M5} "
            "--mpv {wildcards.mpv}"
        )



