# -------------------------------------------------
# WILSON FLOW RULES:
# -------------------------------------------------
#  1) Wilson flow rule for the extraction of w0
#     and the topological charge. It calls 
#     the tau_int script to compute the
#     integrated autocorrelation time.   
# -------------------------------------------------


rule wflow:
    input:
        "raw_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/log"
    output:
        summary="intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/wflow/wflow_extract.json",
        plot_wflow=multiext(
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/wflow/w0_extract",
            config["plot_filetype"]),
        plot_q0=multiext(
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/wflow/topcharge_0",
            config["plot_filetype"]),
        plot_qw0=multiext(
            "intermediary_data/NF{NF}/Nt{Nt}/Ns{Ns}/Ls{Ls}/B{beta}/M{mass}/mpv{mpv}/alpha{alpha}/a5{a5}/M5{M5}/wflow/topcharge_w0",
            config["plot_filetype"]),
    conda:
        "envs/analysis.yml"
    params:
        therm=metadata_lookup("therm"),
        delta_traj_w=metadata_lookup("delta_traj_w0"),
        delta_traj_q=metadata_lookup("delta_traj_w0"),
    shell:
        (
            "python src/wflow/wflow.py {input} "
            "--label {config[label]} "
            "--W0 {config[W0_reference]} "
            "--wflow_out {output.summary} "
            "--plot_wflow {output.plot_wflow} "
            "--plot_q0 {output.plot_q0} "
            "--plot_qw0 {output.plot_qw0} "
            "--plot_styles '{config[plot_styles]}' "
            "--beta {wildcards.beta} "
            "--mass {wildcards.mass} "
            "--therm {params.therm} "
            "--delta_traj_w {params.delta_traj_w} "
            "--delta_traj_q {params.delta_traj_q}"
        )


